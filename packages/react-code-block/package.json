{
    "name": "@dongyuzhao/react-code-block",
    "version": "0.1.0",
    "description": "React tree-sitter token stream code block renderer",
    "repository": {
        "type": "git",
        "url": "https://github.com/DongyuZhao/code-block.git",
        "directory": "packages/react-code-block"
    },
    "publishConfig": {
        "access": "public"
    },
    "type": "module",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsc -p tsconfig.json && node scripts/copy-wasm-assets.mjs",
        "test": "pnpm run test:types && vitest run --project unit && pnpm run test:package",
        "test:package": "pnpm run build && node test/package-exports.mjs",
        "test:types": "tsc -p tsconfig.api.json",
        "test:pixel": "vitest run --project browser",
        "test:pixel:update": "vitest run --project browser --update",
        "test:watch": "vitest --project unit"
    },
    "peerDependencies": {
        "react": ">=18.0.0"
    },
    "devDependencies": {
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@types/react": "^18.3.3",
        "@types/react-dom": "^18.3.7",
        "@vitejs/plugin-react": "^6.0.3",
        "@vitest/browser": "^4.1.10",
        "@vitest/browser-playwright": "^4.1.10",
        "jsdom": "^29.1.1",
        "playwright": "^1.61.1",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "typescript": "^5.5.4",
        "vitest": "^4.1.10",
        "vitest-browser-react": "^2.2.0"
    }
}
